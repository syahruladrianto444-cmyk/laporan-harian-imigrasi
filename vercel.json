{
    "version": 2,
    "buildCommand": "composer install --no-dev --optimize-autoloader --no-scripts",
    "outputDirectory": "public",
    "functions": {
        "api/index.php": {
            "runtime": "vercel-php@0.7.2"
        }
    },
    "routes": [
        {
            "src": "/build/(.*)",
            "dest": "/build/$1"
        },
        {
            "src": "/(css|js|images|fonts|favicon\\.ico)(.*)",
            "dest": "/$1$2"
        },
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ],
    "env": {
        "APP_ENV": "production",
        "APP_DEBUG": "false",
        "DB_CONNECTION": "mysql",
        "MYSQL_ATTR_SSL_CA": "database/certs/isrgrootx1.pem"
    }
}
