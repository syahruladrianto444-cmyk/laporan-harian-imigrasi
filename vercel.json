{
    "version": 2,
    "builds": [
        {
            "src": "api/index.php",
            "use": "vercel-php@0.7.2"
        },
        {
            "src": "public/**/*",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        {
            "src": "/build/(.*)",
            "dest": "/public/build/$1"
        },
        {
            "src": "/(css|js|images|fonts|favicon\\.ico)(.*)",
            "dest": "/public/$1$2"
        },
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ],
    "env": {
        "APP_ENV": "production",
        "APP_DEBUG": "false",
        "APP_URL": "https://laporan-imigrasi-harian.vercel.app",
        "APP_KEY": "base64:p+F+w3r/MuP9nHqOYgVpURUK60a2+tp44KQcopmNY3M=",
        "DB_CONNECTION": "mysql",
        "COMPOSER_INSTALL_ARGS": "--no-dev --no-scripts --no-plugins --optimize-autoloader"
    }
}
