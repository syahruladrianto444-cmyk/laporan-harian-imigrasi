{
    "version": 2,
    "framework": null,
    "buildCommand": "echo 'Build skipped'",
    "functions": {
        "api/*.php": {
            "runtime": "vercel-php@0.7.2"
        }
    },
    "routes": [
        {
            "src": "/build/(.*)",
            "dest": "/public/build/$1"
        },
        {
            "src": "/(css|js|images|fonts|favicon\\.ico)(.*)",
            "dest": "/public/$1$2"
        },
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ],
    "env": {
        "APP_ENV": "production",
        "APP_DEBUG": "true",
        "APP_KEY": "base64:p+F+w3r/MuP9nHqOYgVpURUK60a2+tp44KQcopmNY3M=",
        "DB_CONNECTION": "mysql",
        "COMPOSER_INSTALL_ARGS": "--no-dev --no-scripts --no-plugins --optimize-autoloader"
    }
}
